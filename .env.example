# Database
DATABASE_URL="mysql://user:password@localhost:3306/everest_admin"

# NextAuth
NEXTAUTH_SECRET="your-nextauth-secret"
NEXTAUTH_URL="http://localhost:3000"

# Google Auth (Optional)
GOOGLE_CLIENT_ID="xxx"
GOOGLE_CLIENT_SECRET="xxx"

# Resend (Required for transactional + bulk emails)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM='"Everest Academy" <noreply@yourdomain.com>'

# Magic Link Configuration (optional, defaults shown)
MAGIC_LINK_TTL_MINUTES="15"
MAGIC_LINK_RATE_LIMIT_MAX="3"
MAGIC_LINK_RATE_LIMIT_WINDOW_MINUTES="15"
MAGIC_LINK_RESEND_COOLDOWN_SECONDS="60"
