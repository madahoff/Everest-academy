# Database
DATABASE_URL="mysql://user:password@localhost:3306/everest_admin"

# NextAuth
NEXTAUTH_SECRET="your-nextauth-secret"
NEXTAUTH_URL="http://localhost:3000"

# Google Auth (Optional)
GOOGLE_CLIENT_ID="xxx"
GOOGLE_CLIENT_SECRET="xxx"

# SMTP Configuration (Required for Magic Link emails)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM='"Everest Academy" <noreply@everest.pro>'

# Magic Link Configuration (optional, defaults shown)
MAGIC_LINK_TTL_MINUTES="15"
MAGIC_LINK_RATE_LIMIT_MAX="3"
MAGIC_LINK_RATE_LIMIT_WINDOW_MINUTES="15"
MAGIC_LINK_RESEND_COOLDOWN_SECONDS="60"
